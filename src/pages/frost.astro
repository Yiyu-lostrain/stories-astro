---
import Layout from '../layouts/Layout.astro';

// 💡 詩詞庫依然可以放在這裡當純資料，也可以移到下方，但放這裡比較好閱讀
const quotes = [
    "獨倚樓欄斜望市<br>沉思世間百慕華",
    "昨夜如雨落下",
    "冬歌夜雪幾殘盡，曉月寧無聲。<br>俯仰承散絕境旅，蝶逝輓家遊故人。",
    "世人皆醒我獨醉",
    "蟬時雨<br>夏夜空",
    "而我必將逝去<br>願那永恆的未來<br>明豔如初",
    "何日方知我是我",
    "此身此情<br>葬結雨露均芳"
];
---

<Layout title="霜心雨聚" activeNav="frost">
    <section class="frost-center">
        <div class="frost-text" id="daily-frost-content" style="opacity: 0; transition: opacity 0.3s ease;">
            凝聚中...
        </div>
    </section>
</Layout>

<script define:vars={{ quotes }}>
    // 💡 使用 define:vars 把 Astro 區塊的 quotes 陣列安全地傳遞給前端 JavaScript
    
    function renderDailyFrost() {
        const contentEl = document.getElementById('daily-frost-content');
        if (!contentEl) return;

        // 1. 每次讀者打開網頁時，現場抓取當下的時間
        const now = new Date();
        const year = now.getFullYear();
        const month = now.getMonth() + 1;
        const date = now.getDate();

        // 2. 算今天的日期印記（例如 20260607）
        const dateIdentifier = year * 10000 + month * 100 + date;
        const targetIndex = dateIdentifier % quotes.length;
        const todaysQuote = quotes[targetIndex];

        // 3. 因為句子裡面有 <br>，必須使用 innerHTML 瀏覽器才會正確換行
        contentEl.innerHTML = todaysQuote;
        
        // 4. 計算完後再亮起，徹底防範「閃爍」或「看到預設字」的尷尬體感
        contentEl.style.opacity = '1';
    }

    // 第一次載入時執行
    renderDailyFrost();

    // 確保讀者透過 View Transitions 點擊切換過來時，也會重新現場計算
    document.addEventListener('astro:page-load', renderDailyFrost);
</script>