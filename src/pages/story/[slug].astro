---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const stories = await getCollection('stories');
  
  return stories.map((story) => {
    const currentCategoryStories = stories.filter(s => s.data.category === story.data.category);

    const dateSorted = [...currentCategoryStories].sort((a, b) => (b.data.order ?? 0) - (a.data.order ?? 0));
    const orderSorted = [...currentCategoryStories].sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

    const dateIdx = dateSorted.findIndex(s => s.id === story.id);
    const orderIdx = orderSorted.findIndex(s => s.id === story.id);

    return {
      params: { slug: story.id }, 
      props: {
        story,
        datePrev: dateIdx > 0 ? dateSorted[dateIdx - 1] : null,
        dateNext: dateIdx < dateSorted.length - 1 ? dateSorted[dateIdx + 1] : null,
        orderPrev: orderIdx > 0 ? orderSorted[orderIdx - 1] : null,
        orderNext: orderIdx < orderSorted.length - 1 ? orderSorted[orderIdx + 1] : null
      }
    };
  });
}

interface Props {
  story: CollectionEntry<'stories'>;
  datePrev: CollectionEntry<'stories'> | null;
  dateNext: CollectionEntry<'stories'> | null;
  orderPrev: CollectionEntry<'stories'> | null;
  orderNext: CollectionEntry<'stories'> | null;
}

const { story, datePrev, dateNext, orderPrev, orderNext } = Astro.props;
const { Content } = await render(story);

function getCategorySlug(category: string) {
  const mapping: Record<string, string> = {
    '青茸': 'green',
    '分類二': 'blue',
    '生活札記': 'diary',
    '現代詩': 'poetry'
  };
  return mapping[category] || '';
}

const currentCatSlug = getCategorySlug(story.data.category);
const backToCategoryLink = currentCatSlug ? `/stories-astro/category/${currentCatSlug}` : '/stories-astro/stories';
---

<Layout title={story.data.title} activeNav="stories">
    <style>
        article { position: relative; }
        
        .story-navigation {
            display: flex;
            margin-top: 5rem;
            border-top: 1px solid var(--border-color, #eee);
            padding-top: 2rem;
        }

        @media (min-width: 1241px) {
            .desktop-hover-nav { justify-content: center; }
            .bottom-text-nav .nav-group { justify-content: center !important; }

            .hover-zone-prev, .hover-zone-next {
                position: fixed;
                top: 80px; 
                height: calc(100vh - 80px); 
                width: 15vw; 
                z-index: 90;
                display: flex;
                align-items: center;
                pointer-events: auto; 
            }
            .hover-zone-prev { left: 0; justify-content: flex-start; padding-left: 4vw; }
            .hover-zone-next { right: 0; justify-content: flex-end; padding-right: 4vw; }

            .nav-floating-prev, .nav-floating-next {
                position: static; 
                margin: 0;
                margin-top: -2.5rem; 
                font-family: inherit !important;
                font-size: inherit !important;
                font-weight: inherit !important;
                color: inherit !important;
                letter-spacing: inherit !important;
                text-decoration: inherit !important;
                opacity: 0;
                transition: opacity 0.3s ease;
            }
            .hover-zone-prev:hover .nav-floating-prev,
            .hover-zone-next:hover .nav-floating-next { opacity: 1; }
        }

        @media (max-width: 1240px) {
            .story-navigation { justify-content: space-between; align-items: center; }
            .desktop-hover-nav { display: none !important; }
        }

        .nav-group { display: none; width: 100%; justify-content: inherit; align-items: inherit; }
        .nav-group.active { display: flex; }
        
        .back-link-btn { cursor: pointer; }

        /* 💡 ✨ 預設先把「回總覽」按鈕藏起來，用分類按鈕當安全基底 */
        .back-to-stories-btn { display: none !important; }
        .back-to-category-btn { display: inline-block !important; }

        /* 💡 ✨ 當整頁被蓋上 [data-from-source="stories"] 蓋章時，反轉顯示狀態 */
        :root[data-from-source="stories"] .back-to-stories-btn { display: inline-block !important; }
        :root[data-from-source="stories"] .back-to-category-btn { display: none !important; }
    </style>

    <article>
        <div class="article-header">
            <div class="article-meta">
                <span>{story.data.category}</span>
                {story.data.date && ( <> <span>/</span> <span>{story.data.date}</span> </> )}
            </div>
            <h1 class="article-title">{story.data.title}</h1>
        </div>

        <div class="article-content">
            <Content />
        </div>

        {/* 1. 桌上型電腦的兩側懸浮按鈕區塊 */}
        <div class="story-navigation desktop-hover-nav">
            <div class="nav-group date-nav active">
                <div class="hover-zone-prev">
                    {datePrev ? <a href={`/stories-astro/story/${datePrev.id}?sort=date&from=${Astro.url.searchParams.get('from') || ''}`} class="story-nav-link nav-floating-prev">← 上一篇</a> : <span class="story-nav-link disabled nav-floating-prev">← 上一篇</span>}
                </div>
                <div class="hover-zone-next">
                    {dateNext ? <a href={`/stories-astro/story/${dateNext.id}?sort=date&from=${Astro.url.searchParams.get('from') || ''}`} class="story-nav-link nav-floating-next">下一篇 →</a> : <span class="story-nav-link disabled nav-floating-next">下一篇 →</span>}
                </div>
            </div>
            <div class="nav-group order-nav">
                <div class="hover-zone-prev">
                    {orderPrev ? <a href={`/stories-astro/story/${orderPrev.id}?sort=order&from=${Astro.url.searchParams.get('from') || ''}`} class="story-nav-link nav-floating-prev">← 上一篇</a> : <span class="story-nav-link disabled nav-floating-prev">← 上一篇</span>}
                </div>
                <div class="hover-zone-next">
                    {orderNext ? <a href={`/stories-astro/story/${orderNext.id}?sort=order&from=${Astro.url.searchParams.get('from') || ''}`} class="story-nav-link nav-floating-next">下一篇 →</a> : <span class="story-nav-link disabled nav-floating-next">下一篇 →</span>}
                </div>
            </div>
        </div>

        {/* 2. 行動裝置／底部文字按鈕區塊（核心改動：雙按鈕並存） */}
        <div class="story-navigation bottom-text-nav">
            <div class="nav-group date-nav active" style="width:100%; justify-content:space-between; align-items:center;">
                {datePrev ? <a href={`/stories-astro/story/${datePrev.id}?sort=date&from=${Astro.url.searchParams.get('from') || ''}`} class="story-nav-link screen-small-only">← 上一篇</a> : <span class="story-nav-link disabled screen-small-only">← 上一篇</span>}
                
                {/* 顯示哪顆由 CSS 決定，網址在後台就死死寫好，絕對不會錯 */}
                <a href="/stories-astro/stories?sort=date" class="story-nav-link back-link-btn back-to-stories-btn" style="font-size: 0.85rem; letter-spacing: 0.05em;">返回列表</a>
                <a href={`${backToCategoryLink}?sort=date`} class="story-nav-link back-link-btn back-to-category-btn" style="font-size: 0.85rem; letter-spacing: 0.05em;">返回列表</a>
                
                {dateNext ? <a href={`/stories-astro/story/${dateNext.id}?sort=date&from=${Astro.url.searchParams.get('from') || ''}`} class="story-nav-link screen-small-only">下一篇 →</a> : <span class="story-nav-link disabled screen-small-only">下一篇 →</span>}
            </div>
            <div class="nav-group order-nav" style="width:100%; justify-content:space-between; align-items:center;">
                {orderPrev ? <a href={`/stories-astro/story/${orderPrev.id}?sort=order&from=${Astro.url.searchParams.get('from') || ''}`} class="story-nav-link screen-small-only">← 上一篇</a> : <span class="story-nav-link disabled screen-small-only">← 上一篇</span>}
                
                {/* 顯示哪顆由 CSS 決定，網址在後台就死死寫好，絕對不會錯 */}
                <a href="/stories-astro/stories?sort=order" class="story-nav-link back-link-btn back-to-stories-btn" style="font-size: 0.85rem; letter-spacing: 0.05em;">返回列表</a>
                <a href={`${backToCategoryLink}?sort=order`} class="story-nav-link back-link-btn back-to-category-btn" style="font-size: 0.85rem; letter-spacing: 0.05em;">返回列表</a>
                
                {orderNext ? <a href={`/stories-astro/story/${orderNext.id}?sort=order&from=${Astro.url.searchParams.get('from') || ''}`} class="story-nav-link screen-small-only">下一篇 →</a> : <span class="story-nav-link disabled screen-small-only">下一篇 →</span>}
            </div>
        </div>
    </article>

    <button id="back-to-top" title="回到頂部">↑</button>
</Layout>

<style is:global>
    @media (min-width: 1241px) { .screen-small-only { display: none !important; } }
</style>

<script>
    function initNavigationRoute() {
        // 使用 setTimeout 確保這段邏輯在瀏覽器完成「轉場動畫」並「渲染完 HTML」後才執行
        setTimeout(() => {
            const urlParams = new URLSearchParams(window.location.search);
            
            // 1. 處理排序切換 active
            const sortType = urlParams.get('sort') || 'date';
            const dateNavs = document.querySelectorAll('.date-nav');
            const orderNavs = document.querySelectorAll('.order-nav');
            
            if (sortType === 'order') {
                dateNavs.forEach(el => el.classList.remove('active'));
                orderNavs.forEach(el => el.classList.add('active'));
            } else {
                orderNavs.forEach(el => el.classList.remove('active'));
                dateNavs.forEach(el => el.classList.add('active'));
            }

            // 2. 判斷來源並蓋章 (這裡的 DOM 操作最容易引發抖動，所以放在 setTimeout 內)
            const fromParam = urlParams.get('from');
            if (fromParam === 'stories') {
                document.documentElement.setAttribute('data-from-source', 'stories');
                sessionStorage.setItem('story_from_stories_view', 'true');
            } else if (sessionStorage.getItem('story_from_stories_view') === 'true') {
                document.documentElement.setAttribute('data-from-source', 'stories');
            } else {
                document.documentElement.removeAttribute('data-from-source');
            }
        }, 0);

        // 3. 事件綁定 (這部分不影響渲染，可以維持原樣)
        const backBtns = document.querySelectorAll('.back-link-btn');
        backBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                sessionStorage.removeItem('story_from_stories_view');
            });
        });

        // 4. 回到頂部按鈕 (這是互動邏輯，不會影響首幀，可以維持原樣)
        const backToTopBtn = document.getElementById('back-to-top');
        if (backToTopBtn) {
            const handleScroll = () => {
                backToTopBtn.classList.toggle('show', window.scrollY > 400);
            };
            window.removeEventListener('scroll', handleScroll);
            window.addEventListener('scroll', handleScroll);
            backToTopBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
        }
    }

    // 啟動與監聽
    initNavigationRoute();
    document.addEventListener('astro:after-swap', initNavigationRoute);
</script>