---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const stories = await getCollection('stories');
  
  return stories.map((story) => {
    const currentCategoryStories = stories.filter(s => s.data.category === story.data.category);

    const dateSorted = [...currentCategoryStories].sort((a, b) => (b.data.order ?? 0) - (a.data.order ?? 0));
    const orderSorted = [...currentCategoryStories].sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

    const dateIdx = dateSorted.findIndex(s => s.id === story.id);
    const orderIdx = orderSorted.findIndex(s => s.id === story.id);

    return {
      params: { slug: story.id }, 
      props: {
        story,
        datePrev: dateIdx > 0 ? dateSorted[dateIdx - 1] : null,
        dateNext: dateIdx < dateSorted.length - 1 ? dateSorted[dateIdx + 1] : null,
        orderPrev: orderIdx > 0 ? orderSorted[orderIdx - 1] : null,
        orderNext: orderIdx < orderSorted.length - 1 ? orderSorted[orderIdx + 1] : null
      }
    };
  });
}

interface Props {
  story: CollectionEntry<'stories'>;
  datePrev: CollectionEntry<'stories'> | null;
  dateNext: CollectionEntry<'stories'> | null;
  orderPrev: CollectionEntry<'stories'> | null;
  orderNext: CollectionEntry<'stories'> | null;
}

const { story, datePrev, dateNext, orderPrev, orderNext } = Astro.props;
const { Content } = await render(story);

// 💡 這裡保留作為「備用網址」，如果讀者直接複製網址進來（沒有上一頁），就去分類展開頁
function getBackLink(category: string) {
  const routes: Record<string, string> = {
    '青茸': '/category/green',
    '分類二': '/category/blue',
    '生活札記': '/category/diary',
    '現代詩': '/category/poetry'
  };
  return routes[category] || '/stories';
}

const backToCategoryLink = getBackLink(story.data.category);
---

<Layout title={story.data.title} activeNav="stories">
    <style>
        article { position: relative; }
        
        .story-navigation {
            display: flex;
            margin-top: 5rem;
            border-top: 1px solid var(--border-color, #eee);
            padding-top: 2rem;
        }

        @media (min-width: 1241px) {
            .desktop-hover-nav { justify-content: center; }
            .bottom-text-nav .nav-group { justify-content: center !important; }

            .hover-zone-prev, .hover-zone-next {
                position: fixed;
                top: 80px; 
                height: calc(100vh - 80px); 
                width: 15vw; 
                z-index: 90;
                display: flex;
                align-items: center;
                pointer-events: auto; 
            }
            .hover-zone-prev { left: 0; justify-content: flex-start; padding-left: 4vw; }
            .hover-zone-next { right: 0; justify-content: flex-end; padding-right: 4vw; }

            .nav-floating-prev, .nav-floating-next {
                position: static; 
                margin: 0;
                margin-top: -2.5rem; 
                font-family: inherit !important;
                font-size: inherit !important;
                font-weight: inherit !important;
                color: inherit !important;
                letter-spacing: inherit !important;
                text-decoration: inherit !important;
                opacity: 0;
                transition: opacity 0.3s ease;
            }
            .hover-zone-prev:hover .nav-floating-prev,
            .hover-zone-next:hover .nav-floating-next { opacity: 1; }
        }

        @media (max-width: 1240px) {
            .story-navigation { justify-content: space-between; align-items: center; }
            .desktop-hover-nav { display: none !important; }
        }

        .nav-group { display: none; width: 100%; justify-content: inherit; align-items: inherit; }
        .nav-group.active { display: flex; }
        
        /* 💡 讓返回按鈕看起來跟原本一樣，但加上手勢指標 */
        .back-link-btn { cursor: pointer; }
    </style>

    <article>
        <div class="article-header">
            <div class="article-meta">
                <span>{story.data.category}</span>
                {story.data.date && ( <> <span>/</span> <span>{story.data.date}</span> </> )}
            </div>
            <h1 class="article-title">{story.data.title}</h1>
        </div>

        <div class="article-content">
            <Content />
        </div>

        <div class="story-navigation desktop-hover-nav">
            <div class="nav-group date-nav active">
                <div class="hover-zone-prev">
                    {datePrev ? <a href={`/story/${datePrev.id}?sort=date`} class="story-nav-link nav-floating-prev">← 上一篇</a> : <span class="story-nav-link disabled nav-floating-prev">← 上一篇</span>}
                </div>
                <div class="hover-zone-next">
                    {dateNext ? <a href={`/story/${dateNext.id}?sort=date`} class="story-nav-link nav-floating-next">下一篇 →</a> : <span class="story-nav-link disabled nav-floating-next">下一篇 →</span>}
                </div>
            </div>
            <div class="nav-group order-nav">
                <div class="hover-zone-prev">
                    {orderPrev ? <a href={`/story/${orderPrev.id}?sort=order`} class="story-nav-link nav-floating-prev">← 上一篇</a> : <span class="story-nav-link disabled nav-floating-prev">← 上一篇</span>}
                </div>
                <div class="hover-zone-next">
                    {orderNext ? <a href={`/story/${orderNext.id}?sort=order`} class="story-nav-link nav-floating-next">下一篇 →</a> : <span class="story-nav-link disabled nav-floating-next">下一篇 →</span>}
                </div>
            </div>
        </div>

        <div class="story-navigation bottom-text-nav">
            <div class="nav-group date-nav active" style="width:100%; justify-content:space-between; align-items:center;">
                {datePrev ? <a href={`/story/${datePrev.id}?sort=date`} class="story-nav-link screen-small-only">← 上一篇</a> : <span class="story-nav-link disabled screen-small-only">← 上一篇</span>}
                <a href={backToCategoryLink} class="story-nav-link back-link-btn" style="font-size: 0.85rem; letter-spacing: 0.05em;">返回列表</a>
                {dateNext ? <a href={`/story/${dateNext.id}?sort=date`} class="story-nav-link screen-small-only">下一篇 →</a> : <span class="story-nav-link disabled screen-small-only">下一篇 →</span>}
            </div>
            <div class="nav-group order-nav" style="width:100%; justify-content:space-between; align-items:center;">
                {orderPrev ? <a href={`/story/${orderPrev.id}?sort=order`} class="story-nav-link screen-small-only">← 上一篇</a> : <span class="story-nav-link disabled screen-small-only">← 上一篇</span>}
                <a href={backToCategoryLink} class="story-nav-link back-link-btn" style="font-size: 0.85rem; letter-spacing: 0.05em;">返回列表</a>
                {orderNext ? <a href={`/story/${orderNext.id}?sort=order`} class="story-nav-link screen-small-only">下一篇 →</a> : <span class="story-nav-link disabled screen-small-only">下一篇 →</span>}
            </div>
        </div>
    </article>

    <button id="back-to-top" title="回到頂部">↑</button>
</Layout>

<style is:global>
    @media (min-width: 1241px) { .screen-small-only { display: none !important; } }
</style>

<script>
    function initNavigationRoute() {
        const urlParams = new URLSearchParams(window.location.search);
        const sortType = urlParams.get('sort') || 'date';
        const dateNavs = document.querySelectorAll('.date-nav');
        const orderNavs = document.querySelectorAll('.order-nav');

        if (sortType === 'order') {
            dateNavs.forEach(el => el.classList.remove('active'));
            orderNavs.forEach(el => el.classList.add('active'));
        } else {
            orderNavs.forEach(el => el.classList.remove('active'));
            dateNavs.forEach(el => el.classList.add('active'));
        }

        // 💡 【智慧返回邏輯】判斷讀者是從總覽頁來，還是從展開頁來
        const backBtns = document.querySelectorAll('.back-link-btn');
        backBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                const referrer = document.referrer;
                // 如果前一頁的網址包含 '/stories'（總覽頁），就直接用瀏覽器的歷史紀錄上一頁，保留原本的滾動位置！
                if (referrer && (referrer.includes('/stories') || referrer.includes('/category/'))) {
                    e.preventDefault();
                    window.history.back();
                }
                // 如果是其他地方或直接開網址，就維持預設的 href（去展開頁）
            });
        });

        const backToTopBtn = document.getElementById('back-to-top');
        if (!backToTopBtn) return;
        const handleScroll = () => {
            if (window.scrollY > 400) backToTopBtn.classList.add('show');
            else backToTopBtn.classList.remove('show');
        };
        window.removeEventListener('scroll', handleScroll);
        window.addEventListener('scroll', handleScroll);
        backToTopBtn.addEventListener('click', () => { window.scrollTo({ top: 0, behavior: 'smooth' }); });
    }

    initNavigationRoute();
    document.addEventListener('astro:after-swap', initNavigationRoute);
</script>